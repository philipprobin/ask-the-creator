# Copy to .env.local and fill in. Without these the app runs in MOCK mode.

# OpenAI (embeddings + chat). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# YouTube Data API v3 key. Get one in Google Cloud Console.
# https://console.cloud.google.com/apis/credentials  (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# Postgres connection string with pgvector enabled (e.g. Vercel Postgres / Neon).
# Without this the app stores embeddings in memory (cleared on redeploy).
DATABASE_URL=

# Optional model overrides
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
